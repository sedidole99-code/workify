#!/usr/bin/env bash
# Workify — manual start. Idempotent: prints status if already running.

set -e
DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
URL="http://localhost:13001"

if (echo >/dev/tcp/localhost/13001) >/dev/null 2>&1; then
  echo "Workify already running at $URL"
  exit 0
fi

NODE_BIN="$(command -v node || true)"
if [ -z "$NODE_BIN" ] && [ -s "$HOME/.nvm/nvm.sh" ]; then
  # shellcheck disable=SC1090
  . "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
  NODE_BIN="$(command -v node || true)"
fi
if [ -z "$NODE_BIN" ]; then
  echo "Workify: node not found in PATH" >&2
  exit 1
fi

setsid -f "$NODE_BIN" "$DIR/server.js" >/tmp/workify.log 2>&1 < /dev/null
sleep 0.3

if (echo >/dev/tcp/localhost/13001) >/dev/null 2>&1; then
  echo "Workify started at $URL (log: /tmp/workify.log)"
else
  echo "Workify failed to start — check /tmp/workify.log" >&2
  exit 1
fi
